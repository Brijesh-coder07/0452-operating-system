#include <stdio.h>

int main() {
    int n, bt[10], pr[10], rt[10];
    int wt[10]={0}, tat[10];
    int time=0, completed=0, i, min, idx;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    printf("Enter Burst Time:\n");
    for(i=0;i<n;i++){
        scanf("%d",&bt[i]);
        rt[i]=bt[i];
    }

    printf("Enter Priority:\n");
    for(i=0;i<n;i++) scanf("%d",&pr[i]);

    while(completed<n){
        min=9999; idx=-1;

        for(i=0;i<n;i++){
            if(rt[i]>0 && pr[i]<min){
                min=pr[i];
                idx=i;
            }
        }

        rt[idx]--;
        time++;

        if(rt[idx]==0){
            completed++;
            tat[idx]=time;
            wt[idx]=tat[idx]-bt[idx];
        }
    }

    printf("\nBT\tPR\tWT\tTAT\n");
    for(i=0;i<n;i++)
        printf("%d\t%d\t%d\t%d\n",bt[i],pr[i],wt[i],tat[i]);

    return 0;
}
