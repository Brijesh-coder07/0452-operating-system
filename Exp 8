#include <stdio.h>

int main() {
    int n, bt[10], rt[10], wt[10]={0}, tat[10];
    int tq, i, time=0, done;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    printf("Enter Burst Time:\n");
    for(i=0;i<n;i++){
        scanf("%d",&bt[i]);
        rt[i]=bt[i];
    }

    printf("Enter Time Quantum: ");
    scanf("%d",&tq);

    do{
        done=1;
        for(i=0;i<n;i++){
            if(rt[i]>0){
                done=0;
                if(rt[i]>tq){
                    time+=tq;
                    rt[i]-=tq;
                }
                else{
                    time+=rt[i];
                    wt[i]=time-bt[i];
                    rt[i]=0;
                }
            }
        }
    }while(!done);

    for(i=0;i<n;i++)
        tat[i]=bt[i]+wt[i];

    printf("\nBT\tWT\tTAT\n");
    for(i=0;i<n;i++)
        printf("%d\t%d\t%d\n",bt[i],wt[i],tat[i]);

    return 0;
}
